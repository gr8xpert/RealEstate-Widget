            {
              "id": "general-accordion",
              "elType": "widget",
              "widgetType": "accordion",
              "settings": {
                "tabs": [
                  {
                    "tab_title": "What is Smart Property Widget?",
                    "tab_content": "<p>Smart Property Widget is a powerful property listing solution that allows real estate agencies and property websites to display their property listings beautifully. It provides search filters, property grids, carousels, detailed property pages, and many more features to create a professional property website.</p>",
                    "_id": "general-1"
                  },
                  {
                    "tab_title": "How do I get started with Smart Property Widget?",
                    "tab_content": "<p>Getting started is simple:</p><ul><li><strong>WordPress users:</strong> Install and activate the Smart Property Widget plugin from your WordPress admin panel</li><li><strong>Other platforms:</strong> Add a small script to your website and start using the widget components</li></ul><p>Once set up, your properties will automatically sync and display on your website.</p>",
                    "_id": "general-2"
                  },
                  {
                    "tab_title": "Do I need technical knowledge to use the widget?",
                    "tab_content": "<p>No technical knowledge is required for basic usage. The widget comes with ready-made templates that you can simply add to your pages. For WordPress users, you can use page builders like Elementor or Divi to drag and drop components. Advanced customization options are available for those who want more control.</p>",
                    "_id": "general-3"
                  },
                  {
                    "tab_title": "Is my data secure with Smart Property Widget?",
                    "tab_content": "<p>Yes, your data is secure. All data transfers are encrypted using HTTPS. Your property data is synced from your existing property management system and displayed securely on your website. We do not store sensitive client information and follow industry-standard security practices.</p>",
                    "_id": "general-4"
                  }
                ],
