            {
              "id": "compatibility-accordion",
              "elType": "widget",
              "widgetType": "accordion",
              "settings": {
                "tabs": [
                  {
                    "tab_title": "Which platforms is Smart Property Widget compatible with?",
                    "tab_content": "<p>Smart Property Widget works with virtually any website platform:</p><ul><li><strong>WordPress:</strong> Dedicated plugin with easy setup</li><li><strong>Wix:</strong> Add via custom code embed</li><li><strong>Squarespace:</strong> Add via code injection</li><li><strong>Webflow:</strong> Add via custom code</li><li><strong>Custom HTML:</strong> Works with any HTML website</li></ul>",
                    "_id": "compat-1"
                  },
                  {
                    "tab_title": "Does it work with WordPress page builders?",
                    "tab_content": "<p>Yes! Smart Property Widget is fully compatible with popular WordPress page builders including:</p><ul><li>Elementor</li><li>Divi Builder</li><li>WPBakery Page Builder</li><li>Beaver Builder</li><li>Gutenberg (WordPress Block Editor)</li></ul><p>Simply add an HTML block and paste the widget code.</p>",
                    "_id": "compat-2"
                  },
                  {
                    "tab_title": "Is the widget mobile-friendly?",
                    "tab_content": "<p>Absolutely! Smart Property Widget is fully responsive and works perfectly on all devices including smartphones, tablets, laptops, and desktop computers. The layout automatically adjusts to provide the best viewing experience on any screen size.</p>",
                    "_id": "compat-3"
                  },
                  {
                    "tab_title": "Which browsers are supported?",
                    "tab_content": "<p>Smart Property Widget supports all modern browsers including:</p><ul><li>Google Chrome</li><li>Mozilla Firefox</li><li>Safari</li><li>Microsoft Edge</li><li>Opera</li></ul><p>The widget is built with modern web standards to ensure consistent performance across all browsers.</p>",
                    "_id": "compat-4"
                  }
                ],
