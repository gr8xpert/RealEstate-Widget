{
  "name": "realtysoft-widget",
  "version": "3.0.0",
  "description": "RealtySoft Property Widget - Modern real estate property search and display widget",
  "main": "src/core/controller.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:es": "vite build --mode es",
    "build:sw": "vite build --mode sw",
    "build:all": "vite build && vite build --mode es && vite build --mode sw",
    "build:legacy": "node build.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "real-estate",
    "property",
    "widget",
    "search"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@testing-library/dom": "^10.4.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.0"
  }
}
